# Copy this file to .env.local and fill in values before running docker compose.
# .env.local is git-ignored and never committed.

# Destination bucket for the Bedrock Knowledge Base S3 data source.
# NOTE: uploading into the existing cits-rag-s3vector-documents-* bucket will
# trigger the S3 Vectors ingestion Lambda on every file (including the
# .metadata.json sidecars) — use a dedicated KB source bucket instead.
S3_BUCKET_NAME=your-kb-source-bucket

# Key prefix for all uploaded objects (default csms/)
S3_PREFIX=csms/

# AWS credentials — use ONE of the two approaches below:

# Approach A: named profile (matches the ~/.aws/credentials profile you use for CDK)
AWS_PROFILE=terraform

# Approach B: explicit keys (useful in CI or when no profile is configured)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

AWS_DEFAULT_REGION=us-east-1

# Politeness knobs (optional)
# REQUEST_DELAY_SECONDS=0.7
# REQUEST_TIMEOUT_SECONDS=30
# MAX_RETRIES=3
